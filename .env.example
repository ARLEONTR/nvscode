COMPOSE_PROJECT_NAME=nvscode
MYSQL_ROOT_PASSWORD=nextcloud-root
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=admin123
NVSCODE_SHARED_SECRET=replace-with-a-long-random-string
NVSCODE_SESSION_SIGNING_SECRET=replace-with-a-different-long-random-string
NVSCODE_SESSION_TTL_SECONDS=3600
NVSCODE_IDLE_TIMEOUT_SECONDS=3600
NVSCODE_LAUNCHER_CLEANUP_INTERVAL_SECONDS=300
NVSCODE_FILE_SCAN_INTERVAL_SECONDS=15
NEXTCLOUD_DATA_HOST_PATH=/absolute/path/to/bottomroot/docker-data/nextcloud-data
LAUNCHER_STATE_HOST_PATH=/absolute/path/to/bottomroot/docker-data/launcher-state
CODE_SERVER_IMAGE=nvscode-code-server:latest
CODE_SERVER_RUN_AS=33:33
CODE_SERVER_CONTAINER_PREFIX=nvscode-code-server
CODE_SERVER_DEFAULT_EXTENSIONS=myriad-dreamin.tinymist,mathematic.vscode-pdf
